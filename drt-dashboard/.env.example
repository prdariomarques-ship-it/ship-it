# DRT Runtime Dashboard Environment Configuration

# DRT Runtime API URL
# Default: http://localhost:5000 (if not specified)
# Change this if Runtime is on a different machine or port
NEXT_PUBLIC_RUNTIME_API=http://localhost:5000

# Node Environment
NODE_ENV=production

# Examples:
# Local development
# NEXT_PUBLIC_RUNTIME_API=http://localhost:5000

# Remote production
# NEXT_PUBLIC_RUNTIME_API=http://drt-runtime.example.com:5000

# Docker container
# NEXT_PUBLIC_RUNTIME_API=http://runtime:5000

# VM/Container to host machine
# NEXT_PUBLIC_RUNTIME_API=http://host.docker.internal:5000
