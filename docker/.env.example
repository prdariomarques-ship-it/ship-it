# Copy to .env (same directory as docker-compose.yml) and fill in.

# Domain served by Caddy. Use "localhost" for local development;
# use a real domain (e.g. dario.example.com) for automatic HTTPS.
DOMAIN=localhost

# PostgreSQL
POSTGRES_USER=dario
POSTGRES_PASSWORD=change-me
POSTGRES_DB=darioos

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# Obrigatório em produção (o backend recusa subir sem um valor forte, >= 32
# caracteres) — protege /api/webhooks/whatsapp, que exige o header
# X-Webhook-Token com este valor (configure o mesmo valor no provider/n8n).
# generate com: openssl rand -hex 32
WEBHOOK_SECRET=

# LLM provider: openai | anthropic | glm | gemini | ollama
LLM_PROVIDER=openai
# Embeddings sempre precisam de um provedor com API de embeddings de dimensão
# conhecida (openai ou gemini); glm e ollama não são usados para embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GLM_API_KEY=
GEMINI_API_KEY=
# Ollama roda localmente; sem chave, apenas o endereço do servidor
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# WhatsApp provider: openwa | baileys | evolution | official
WHATSAPP_PROVIDER=openwa

# OpenWA (optional API key protecting the OpenWA REST API)
OPENWA_API_KEY=

# Browser-reachable URL for openwa's QR pairing page, shown as a link in
# /admin/whatsapp. Leave empty to hide the link entirely (default) -- it is
# NEVER derived automatically from OPENWA_BASE_URL (that's the backend's
# internal Docker-network address, e.g. http://openwa:8002, unreachable from
# a browser). Only takes effect when WHATSAPP_PROVIDER=openwa.
#
# Expected format: a full http(s):// URL, reachable from whatever device/
# browser you'll use to view the admin dashboard.
#
# Option 1 (simplest -- same-LAN access): point directly at the host's
# mapped port 8002 (see docker-compose.yml's `openwa` service `ports:`):
#   OPENWA_PUBLIC_QR_URL=http://192.168.1.10:8002
#
# Option 2 (recommended if the dashboard is reachable over a real domain/
# HTTPS, e.g. via Caddy): proxy the popup under the same domain instead of
# exposing port 8002 separately, avoiding a second open port and mixed-
# content warnings (dashboard on HTTPS, popup on plain HTTP). Add to
# docker/caddy/Caddyfile:
#   handle_path /openwa-qr/* {
#       reverse_proxy openwa:8002
#   }
# then set:
#   OPENWA_PUBLIC_QR_URL=https://your-domain.example/openwa-qr/
#
# Security: this value is read as plain configuration (never validated
# against or substituted into anything else) and is only ever returned to
# an already-authenticated admin via GET /admin/whatsapp -- it is not a
# secret itself (it points at a QR pairing page, not a credential), but the
# page it points to has no authentication of its own, so prefer Option 2
# (behind your own domain/access control) over exposing port 8002 directly
# on a network you don't fully trust.
OPENWA_PUBLIC_QR_URL=

# Evolution API (se WHATSAPP_PROVIDER=evolution)
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=darioos

# Baileys REST gateway (se WHATSAPP_PROVIDER=baileys)
BAILEYS_BASE_URL=
BAILEYS_API_KEY=

# WhatsApp Cloud API oficial (se WHATSAPP_PROVIDER=official)
OFFICIAL_ACCESS_TOKEN=
OFFICIAL_PHONE_NUMBER_ID=
# Assina os webhooks da Meta (X-Hub-Signature-256); recomendado em produção
OFFICIAL_APP_SECRET=
# Handshake de verificação (GET /webhooks/whatsapp) exigido pela Meta ao
# cadastrar a URL do webhook no App Dashboard — defina um valor qualquer
# aqui e repita o mesmo valor no campo "Verify Token" do Dashboard
OFFICIAL_WEBHOOK_VERIFY_TOKEN=

# Resposta automática ponta a ponta (webhook -> AI Orchestrator -> envio).
# Desative se uma automação externa (n8n) já for responsável pelas respostas,
# para o contato não receber duas respostas para a mesma mensagem.
AUTO_REPLY_ENABLED=true
# Proteção contra loop/flood: respostas automáticas por contato por minuto
AUTO_REPLY_MAX_PER_CONTACT_PER_MINUTE=6
# Tempo máximo de uma execução de agente antes de abortar (timeout)
AGENT_RUN_TIMEOUT_SECONDS=60

# Gmail (opcional — só preencha para ativar a integração de e-mail, somente
# leitura, disponível apenas ao agente "assistant"). Passo a passo completo
# de configuração no Google Cloud Console: docs/EMAIL.md
MAIL_PROVIDER=gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# https://<seu-domínio>/api/mail/oauth/callback (ou http://localhost/api/mail/oauth/callback em dev)
GOOGLE_REDIRECT_URI=
# generate com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_TOKEN_ENCRYPTION_KEY=

# Google Calendar (opcional — mesmo GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET acima;
# cadastre esta segunda URI de redirecionamento no mesmo app OAuth). Passo a
# passo: docs/CALENDAR.md
CALENDAR_PROVIDER=google
# https://<seu-domínio>/api/gcalendar/oauth/callback (ou http://localhost/... em dev)
GOOGLE_CALENDAR_REDIRECT_URI=

# Google Contacts (opcional — mesmo GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET acima;
# cadastre esta terceira URI de redirecionamento no mesmo app OAuth). Passo a
# passo: docs/CONTACTS.md
CONTACTS_PROVIDER=google
# https://<seu-domínio>/api/gcontacts/oauth/callback (ou http://localhost/... em dev)
GOOGLE_CONTACTS_REDIRECT_URI=

# Google Drive (opcional — mesmo GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET acima;
# cadastre esta quarta URI de redirecionamento no mesmo app OAuth). Passo a
# passo: docs/DRIVE.md
DRIVE_PROVIDER=google
# https://<seu-domínio>/api/gdrive/oauth/callback (ou http://localhost/... em dev)
GOOGLE_DRIVE_REDIRECT_URI=
# Arquivo maior que isto (bytes) é recusado antes de baixar
GDRIVE_MAX_FILE_SIZE_BYTES=20000000

# n8n public webhook base URL (used in workflow webhook URLs)
N8N_WEBHOOK_URL=http://localhost:5678/

# CORS origins allowed by the backend (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:3000

# Monitoring & Alerting (OBS-001)
# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# Alertmanager routing
# Webhook URL for critical alerts (e.g., PagerDuty, custom handler)
ALERTMANAGER_WEBHOOK_URL=

# Webhook secret for HMAC-SHA256 auth (generate with: openssl rand -hex 32)
ALERTMANAGER_WEBHOOK_SECRET=

# Slack webhook for warning alerts
SLACK_WEBHOOK_URL=

# Email configuration for alerts
# Critical alerts email recipient
ALERT_EMAIL_CRITICAL=

# Default alerts email recipient
ALERT_EMAIL_DEFAULT=

# SMTP configuration for email alerts
SMTP_HOST=
SMTP_PORT=587

# Distributed Tracing (OBS-002) — Optional OpenTelemetry tracing
# Disabled by default (no collector in every environment this runs in);
# enable with OTEL_ENABLED=true and set OTEL_EXPORTER_OTLP_ENDPOINT to
# your backend (e.g. Jaeger, Tempo, Honeycomb, vendor collector).
# When enabled with no endpoint, spans print to stdout (console exporter).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

TZ=America/Sao_Paulo
